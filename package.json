{
	"name": "chronoscroll",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/externalize-inline.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p pipeline",
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"data:build": "tsx pipeline/run/build.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.1.10",
		"js-yaml": "^5.2.1",
		"playwright-core": "^1.61.1",
		"svelte": "^5.56.7",
		"svelte-check": "^4.7.3",
		"tsx": "^4.23.1",
		"typescript": "^7.0.2",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@vercel/analytics": "^2.0.1",
		"minisearch": "^7.2.0"
	},
	"overrides": {
		"cookie": "^0.7.2"
	}
}
